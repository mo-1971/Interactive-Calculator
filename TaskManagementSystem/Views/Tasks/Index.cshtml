@model IEnumerable<TaskManagementSystem.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks Dashboard";
}

<h1>Tasks Dashboard</h1>

<p class="mt-3 mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New Task</a>
</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0 bg-white">
        <thead class="bg-light">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Description)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.DueDate)
                </th>
                <th>
                    Status
                </th>
                <th>
                    Created At
                </th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.Title)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @(item.DueDate.HasValue ? item.DueDate.Value.ToShortDateString() : "-")
                </td>
                <td>
                    @if(item.IsCompleted)
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                </td>
                <td>
                    @item.CreatedAt.ToShortDateString()
                </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
